# Discord Bot Token
# Get from: https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# Riot Games API Key
# Get from: https://developer.riotgames.com/
# Note: Development keys expire every 24 hours
RIOT_API_KEY=your_riot_api_key_here

# Update interval in seconds (default: 3600 = 1 hour)
UPDATE_INTERVAL=3600

# Match notification check interval in seconds (default: 300 = 5 minutes)
NOTIFICATION_INTERVAL=300

# Timezone for displaying timestamps (default: UTC)
# Examples: Europe/Warsaw, America/New_York, Asia/Tokyo
TIMEZONE=UTC
